{
    "packages": ["./", "packages/*"],
    "version": "1.1.1",
    "command": {
        "publish": {
            "forcePublish": true
        },
        "version": {
            "conventionalCommits": true,
            "message": "chore(release): %v",
            "push": false,
            "changelogPreset": {
                "name": "conventionalcommits",
                "compareUrlFormat": "",
                "commitUrlFormat": "{{host}}/{{owner}}/{{repository}}/commits/{{hash}}"
            }
        }
    }
}
