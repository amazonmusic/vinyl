{
    "name": "@amazon/vinyl-mock-generator",
    "version": "1.2.0",
    "description": "Generates mock classes from interfaces",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/amazonmusic/vinyl.git"
    },
    "license": "Apache-2.0",
    "main": "./dist/index.cjs",
    "types": "dist/index.d.ts",
    "type": "module",
    "files": [
        "dist/*"
    ],
    "scripts": {
        "build": "tsc -p ./src/tsconfig.json",
        "build:release": "tsc -p ./src/tsconfig.json",
        "build:watch": "tsc -p ./src/tsconfig.json -w",
        "clean": "rimraf --glob dist .eslintcache \"**/*.tsbuildinfo\"",
        "eslint:check": "eslint . --cache --max-warnings=0",
        "eslint:write": "eslint . --cache --fix",
        "lint": "npm run eslint:check && npm run prettier:check",
        "lint:write": "npm run eslint:write && npm run prettier:write",
        "prettier:check": "prettier . --ignore-path ../../.prettierignore --cache --check",
        "prettier:write": "prettier . --ignore-path ../../.prettierignore --cache --write",
        "release": "npm run lint && npm run build:release"
    },
    "module": "./dist/index.js",
    "exports": {
        ".": {
            "development": "./src/index.ts",
            "import": "./dist/index.js"
        }
    },
    "typesVersions": {}
}
