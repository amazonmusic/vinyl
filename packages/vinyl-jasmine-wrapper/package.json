{
    "name": "@amazon/vinyl-jasmine-wrapper",
    "version": "1.2.0",
    "description": "A wrapper for jasmine core to allow an html runner to boot on legacy browsers",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/amazonmusic/vinyl.git"
    },
    "license": "Apache-2.0",
    "module": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "type": "module",
    "files": [
        "dist/*"
    ],
    "scripts": {
        "clean": "rimraf --glob dist \"**/*.tsbuildinfo\"",
        "build": "tsc",
        "build:release": "npm run build",
        "prettier:check": "prettier . --ignore-path ../../.prettierignore --cache --check",
        "prettier:write": "prettier . --ignore-path ../../.prettierignore --cache --write",
        "lint": "npm run oxlint:check && npm run prettier:check",
        "lint:write": "npm run oxlint:write && npm run prettier:write",
        "test": "echo done",
        "test:coverage": "echo done",
        "oxlint:check": "oxlint --type-aware --deny-warnings",
        "oxlint:write": "oxlint --type-aware --fix"
    },
    "main": "./dist/index.cjs",
    "exports": {
        ".": {
            "development": "./src/index.ts",
            "import": "./dist/index.js"
        }
    },
    "typesVersions": {}
}
