{
    "name": "@amazon/vinyl-website",
    "version": "1.1.1",
    "description": "Documentation, demos and tutorials for the Amazon Vinyl player",
    "private": true,
    "repository": {
        "type": "git",
        "url": "git+https://github.com/amazonmusic/vinyl.git"
    },
    "license": "UNLICENSED",
    "type": "module",
    "scripts": {
        "start": "vite",
        "build": "vite build",
        "build:release": "npm run typedoc && vite build",
        "prepreview": "npm run build",
        "preview": "vite preview",
        "typedoc": "typedoc",
        "clean": "rimraf --glob dist public/tsdocs .eslintcache \"**/*.tsbuildinfo\"",
        "prettier:check": "prettier . --ignore-path ../../.prettierignore --cache --check",
        "prettier:write": "prettier . --ignore-path ../../.prettierignore --cache --write",
        "eslint:check": "eslint . --cache --max-warnings=0",
        "eslint:write": "eslint . --cache --fix",
        "stylelint": "npm run build && stylelint \"dist/assets/*.css\"",
        "lint": "npm run eslint:check && npm run prettier:check",
        "lint:write": "npm run eslint:write && npm run prettier:write",
        "test": ""
    },
    "devDependencies": {
        "@vitejs/plugin-legacy": "^8.0.2",
        "autoprefixer": "^10.5.0",
        "glob": "^13.0.0",
        "highlight.js": "^11.10.0",
        "marked": "^14.0.0",
        "marked-highlight": "^2.2.4",
        "postcss": "^8.5.15",
        "postcss-preset-env": "^11.3.0",
        "postcss-scss": "^4.0.9",
        "sass": "^1.77.0",
        "stylelint": "^17.12.0",
        "stylelint-no-unsupported-browser-features": "^8.1.1",
        "typedoc": "^0.28.4",
        "vite": "^8.0.16"
    },
    "dependencies": {
        "@amazon/vinyl": "^1.1.1",
        "@amazon/vinyl-observable": "^1.1.1",
        "@amazon/vinyl-tsx": "^1.1.1",
        "@amazon/vinyl-util": "^1.1.1",
        "@juggle/resize-observer": "^3.4.0"
    },
    "browserslist": [
        "defaults",
        "not op_mini all"
    ]
}
