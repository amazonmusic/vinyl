{
    "name": "@amazon/vinyl-util",
    "version": "1.2.0",
    "description": "Standard utilities for browser and node.",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/amazonmusic/vinyl.git"
    },
    "license": "Apache-2.0",
    "module": "./dist/index.js",
    "main": "./dist/index.cjs",
    "types": "./dist/types/ts3.7/index.d.ts",
    "type": "module",
    "sideEffects": [
        "**/polyfill/**",
        "test/**/*"
    ],
    "files": [
        "dist/*",
        "docs/*"
    ],
    "typesVersions": {
        ">=5.4": {
            "*": [
                "./dist/types/current/index.d.ts"
            ],
            "testUtil": [
                "./dist/testUtil/types/current/index.d.ts"
            ],
            "browserTestUtil": [
                "./dist/browserTestUtil/types/current/index.d.ts"
            ]
        },
        ">=4.7": {
            "*": [
                "./dist/types/ts4.7/index.d.ts"
            ],
            "testUtil": [
                "./dist/testUtil/types/ts4.7/index.d.ts"
            ],
            "browserTestUtil": [
                "./dist/browserTestUtil/types/ts4.7/index.d.ts"
            ]
        },
        ">=4.1": {
            "*": [
                "./dist/types/ts4.1/index.d.ts"
            ],
            "testUtil": [
                "./dist/testUtil/types/ts4.1/index.d.ts"
            ],
            "browserTestUtil": [
                "./dist/browserTestUtil/types/ts4.1/index.d.ts"
            ]
        },
        ">=3.7": {
            "*": [
                "./dist/types/ts3.7/index.d.ts"
            ],
            "testUtil": [
                "./dist/testUtil/types/ts3.7/index.d.ts"
            ],
            "browserTestUtil": [
                "./dist/browserTestUtil/types/ts3.7/index.d.ts"
            ]
        }
    },
    "exports": {
        ".": {
            "development": "./src/index.ts",
            "types@>=5.4": "./dist/types/current/index.d.ts",
            "types@>=4.7": "./dist/types/ts4.7/index.d.ts",
            "require": "./dist/index.cjs",
            "import": "./dist/index.js"
        },
        "./testUtil": {
            "development": "./test/testUtil/index.ts",
            "types@>=5.4": "./dist/testUtil/types/current/index.d.ts",
            "types@>=4.7": "./dist/testUtil/types/ts4.7/index.d.ts",
            "import": "./dist/testUtil/index.js"
        },
        "./polyfill": {
            "development": "./polyfill/index.ts",
            "import": "./dist/polyfill/index.js"
        },
        "./browserTestUtil": {
            "development": "./test/browserTestUtil/index.ts",
            "types@>=5.4": "./dist/browserTestUtil/types/current/index.d.ts",
            "types@>=4.7": "./dist/browserTestUtil/types/ts4.7/index.d.ts",
            "import": "./dist/browserTestUtil/index.js"
        }
    },
    "scripts": {
        "analyzeExports": "tsx buildSrc/analyzeExports.ts",
        "analyzeExports:write": "tsx buildSrc/analyzeExports.ts --write",
        "clean": "rimraf --glob dist \"**/*.tsbuildinfo\"",
        "indexFiles:check": "tsx buildSrc/writeIndexFiles.ts --check",
        "indexFiles:write": "tsx buildSrc/writeIndexFiles.ts",
        "generateDomMocks": "tsx buildSrc/generateDomMocks.ts && npm run prettier:write",
        "build": "tsx buildSrc/build.ts",
        "build:release": "tsx buildSrc/build.ts --release && tsc --project test/unit",
        "prettier:check": "prettier . --ignore-path ../../.prettierignore --cache --check",
        "prettier:write": "prettier . --ignore-path ../../.prettierignore --cache --write",
        "lint": "npm run indexFiles:check && npm run oxlint:check && npm run prettier:check",
        "lint:write": "npm run indexFiles:write && npm run oxlint:write && npm run prettier:write",
        "test": "tsx ../../node_modules/jasmine/bin/jasmine --config=test/unit/jasmine.config.json",
        "test:coverage": "c8 npm run test",
        "watch": "tsx buildSrc/build.ts --watch",
        "watch:release": "tsx buildSrc/build.ts --watch --release",
        "oxlint:check": "oxlint --type-aware --deny-warnings",
        "oxlint:write": "oxlint --type-aware --fix"
    },
    "devDependencies": {
        "@amazon/vinyl-build-utils": "^1.2.0",
        "@amazon/vinyl-jasmine-wrapper": "^1.2.0",
        "@amazon/vinyl-mock-generator": "^1.2.0"
    }
}
