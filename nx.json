{
    "$schema": "./node_modules/nx/schemas/nx-schema.json",
    "namedInputs": {
        "lintConfig": [
            "default",
            "{workspaceRoot}/buildSrc/lint/**/*",
            "{workspaceRoot}/eslint.config.js",
            "{workspaceRoot}/.prettierignore",
            "{workspaceRoot}/.prettierrc.json"
        ]
    },
    "targetDefaults": {
        "build": {
            "outputs": ["{projectRoot}/dist"],
            "cache": true
        },
        "build:release": {
            "outputs": ["{projectRoot}/dist"],
            "cache": true
        },
        "test:browserstack": {
            "dependsOn": ["^test:browserstack"],
            "cache": true
        },
        "lint": {
            "cache": true,
            "inputs": ["default", "lintConfig"]
        },
        "lint:write": {
            "cache": true,
            "inputs": ["default", "lintConfig"]
        },
        "test": {
            "cache": true
        },
        "test:coverage": {
            "cache": true,
            "outputs": ["{projectRoot}/coverage"]
        },
        "analyzeExports": {
            "dependsOn": ["build:release", "^build:release"],
            "cache": true
        }
    },
    "defaultBase": "main",
    "analytics": false
}
